{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "name": "StaFlow — App do Funcionário",
  "short_name": "StaFlow",
  "description": "Bata seu ponto, veja tarefas e envie atestados direto do celular.",
  "start_url": "/colaborador",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
  "theme_color": "#0d0f12",
  "background_color": "#0d0f12",
  "lang": "pt-BR",
  "dir": "ltr",
  "categories": ["business", "productivity", "utilities"],
  "icons": [
    {
      "src": "/assets/icon-180.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/assets/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Bater ponto",
      "short_name": "Ponto",
      "description": "Abre direto na tela de ponto",
      "url": "/colaborador",
      "icons": [{ "src": "/assets/logo-mark.svg", "sizes": "any", "type": "image/svg+xml" }]
    }
  ]
}
